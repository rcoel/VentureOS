# === LLM ===
OPENAI_API_KEY=sk-...

# === Sourcing tools ===
GITHUB_TOKEN=ghp_...                    # classic PAT, public_repo scope is enough
TAVILY_API_KEY=tvly-...
SERPAPI_API_KEY=...
SEMANTIC_SCHOLAR_API_KEY=               # optional; leave blank for unauthenticated (slower)

# === Database ===
DATABASE_URL=postgresql+psycopg://user:pass@host:5432/ventureos
# For local dev without Postgres, the pipeline works standalone using the SQLite cache.

# === Runtime ===
VENTUREOS_CACHE_PATH=.cache/ventureos.db
VENTUREOS_LOG_LEVEL=INFO

# === Model selection ===
OPENAI_MODEL_FAST=gpt-4o-mini           # extraction, intake, screening, attributes
OPENAI_MODEL_SMART=gpt-4o               # verification, market synthesis, activation